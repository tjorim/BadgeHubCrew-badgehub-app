{
  "name": "badgehub-app",
  "version": "1.0.0",
  "description": "> Node.js REST service for the BadgeHub",
  "homepage": "https://github.com/badgehubcrew/badgehub-app#readme",
  "bugs": {
    "url": "https://github.com/badgehubcrew/badgehub-app/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/badgehubcrew/badgehub-app.git"
  },
  "license": "ISC",
  "author": "",
  "type": "module",
  "scripts": {
    "test": "pnpm -r test",
    "build": "pnpm -r build",
    "check:ts": "pnpm --filter frontend check:ts && pnpm --filter badgehub-api check:ts",
    "start": "pnpm --filter badgehub-api start",
    "dev": "concurrently -k -c 'auto' 'pnpm --filter frontend dev' 'pnpm --filter badgehub-api dev'",
    "dev:frontend": "pnpm --filter frontend dev",
    "test-db:up": "pnpm --filter badgehub-api run test-db:up | exit 0",
    "backup": "docker exec -it badgehub-db /usr/bin/pg_dump --username badgehub badgehub -f /var/backup/data-backup-`date +\"%Y-%m-%dT%H:%m\"`.sql",
    "dev:backend": "pnpm --filter badgehub-api run test-db:up && pnpm --filter badgehub-api dev",
    "dump-db": "docker exec -it badgehub-db /usr/bin/pg_dump --username badgehub --schema badgehub badgehub > mockup-data.sql",
    "prepare": "husky",
    "lint-staged": "pretty-quick --staged",
    "lint": "pretty-quick --check",
    "lint:fix": "pretty-quick",
    "validate": "pnpm run lint && pnpm run check:ts && pnpm run build && pnpm run test"
  },
  "dependencies": {
    "@ts-rest/core": "3.53.0-rc.1",
    "zod": "^3.25.42"
  },
  "devDependencies": {
    "concurrently": "9.1.2",
    "husky": "^9.0.11",
    "prettier": "^3.2.5",
    "pretty-quick": "^4.0.0",
    "typescript": "^7.0.2"
  },
  "packageManager": "pnpm@11.13.0"
}
