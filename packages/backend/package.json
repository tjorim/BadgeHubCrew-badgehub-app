{
  "name": "badgehub-api",
  "version": "1.0.0",
  "description": "Node project for the BadgeHub API",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "start": "node dist/index.mjs",
    "start:pm2": "pm2-runtime process.json",
    "build": "node --experimental-strip-types esbuild/esbuild.config.ts",
    "check:ts": "tsc --noEmit -p tsconfig.json",
    "dev": "node --watch --import tsx src/index.ts",
    "repopulate-db": "node --import tsx src/dev/populate-db/runPopulateDB.ts",
    "test-db:up": "docker compose -f docker-compose.test-db.yml up -d --wait",
    "test-db:down": "docker compose -f docker-compose.test-db.yml down",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "db-migrate:up": "db-migrate up",
    "db-migrate:down": "db-migrate down",
    "db-migrate:create": "db-migrate create --sql-file true",
    "mqtt-monitor": "node --env-file=.env src/dev/mqtt-monitor.js "
  },
  "license": "MIT",
  "engines": {
    "node": ">=24.4.1 <25"
  },
  "dependencies": {
    "@ts-rest/core": "3.53.0-rc.1",
    "@ts-rest/express": "3.53.0-rc.1",
    "@ts-rest/open-api": "3.53.0-rc.1",
    "@types/lodash": "^4.17.24",
    "blurhash": "^2.0.5",
    "cors": "^2.8.6",
    "db-migrate": "^0.11.14",
    "db-migrate-pg": "^1.5.2",
    "dotenv": "^16.6.1",
    "express": "^4.22.2",
    "express-rate-limit": "^7.5.1",
    "jose": "^5.10.0",
    "lodash": "^4.18.1",
    "lru-cache": "^11.5.2",
    "mime-types": "^2.1.35",
    "moment": "^2.30.1",
    "mqtt": "^5.15.2",
    "multer": "^2.2.0",
    "openapi3-ts": "^2.0.2",
    "pg": "^8.22.0",
    "pino-http": "^10.5.0",
    "pm2": "^5.4.3",
    "shared": "workspace:*",
    "sharp": "^0.34.5",
    "sql-template-tag": "^5.2.1",
    "swagger-ui-express": "^5.0.1",
    "tslib": "^2.8.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/mime-types": "^3.0.1",
    "@types/multer": "^1.4.13",
    "@types/node": "^22.20.1",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.3",
    "@types/swagger-ui-express": "^4.1.8",
    "@vitest/coverage-v8": "^4.1.10",
    "concurrently": "^8.2.2",
    "esbuild": "^0.27.7",
    "supertest": "^7.2.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
