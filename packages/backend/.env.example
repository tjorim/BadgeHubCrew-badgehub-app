POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=badgehub
POSTGRES_USER=badgehub
POSTGRES_PASSWORD=badgehub

NODE_APP_INSTANCE=0
NODE_ENV=development

KEYCLOAK_BASE_URL=https://keycloak.p1m.nl
KEYCLOAK_REALM=master
KEYCLOAK_CLIENT_ID=badgehub-api-frontend

CATEGORY_NAMES=Uncategorised,Event related,Games,Graphics,Hardware,Utility,Wearable,Data,Silly,Hacking,Troll,Unusable,Adult,Virus,SAO,Interpreter
ADMIN_CATEGORY_NAMES=Default
BADGE_SLUGS=why2025,troopers23,mch2022
BADGEHUB_API_BASE_URL=http://localhost:8081

# Optional: set this to your Keycloak user's `sub` claim before running
# `npm run repopulate-db` to make all fixture projects editable by that user.
# DEV_USER_SUB=

# MQTT reporting is optional. Leave MQTT_SERVER unset to disable it.
# MQTT_USER=
# MQTT_PASSWD=
# MQTT_TOPIC=
# MQTT_SERVER=
# MQTT_INTERVAL_SEC=300

REFRESH_REPORTS_INTERVAL_SEC=60
